# PostgreSQL (개발: 도커 postgres:15, 포트 5432)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/smarthome

# MQTT (개발: Mosquitto, allow_anonymous false — packages/db `provision:mqtt-auth`가
# 아래 두 값을 자동으로 채워준다. 직접 채울 경우 svc-backend 계정 비밀번호를 넣는다)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# TLS (프로덕션 전용, PROJECT_RULES §5.1 — docs/tls-deployment.md 참고). 개발은 비워두면
# 평문(docker-compose.dev.yml)을 그대로 쓴다. 프로덕션은 infra/tls/generate-certs.sh로
# 자체 서명 CA/서버 인증서를 만든 뒤 아래를 채운다.
# MQTT_URL=mqtts://<host>:8883
MQTT_CA_FILE=
# apps/api HTTPS/WSS — 둘 다 있어야 켜진다(하나만 있으면 무시하고 http로 기동)
TLS_CERT_FILE=
TLS_KEY_FILE=

# Redis (명령 ack correlation / timeout)
REDIS_URL=redis://localhost:6379
COMMAND_SLA_MS=30000

# API JWT (개발 예시. 운영에서는 32자 이상 고난도 secret으로 교체)
AUTH_JWT_SECRET=change-me-change-me-change-me-32chars
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=1209600

# MediaMTX publish 인증 (M17) — RTSP로 publish하는 모든 카메라/mock-camera가 공통으로
# 아는 공유 자격증명. rtsp://<user>:<password>@host:8554/<path> 형태로 카메라 쪽 RTSP URL에
# 실어야 한다. apps/media-gateway의 auth 웹훅(decideAuth)이 publish 액션마다 검사한다.
MEDIAMTX_PUBLISH_USERNAME=change-me
MEDIAMTX_PUBLISH_PASSWORD=change-me
