{
  "name": "@smarthome/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo",
    "start": "dotenv -e ../../.env -- node dist/index.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@smarthome/auth": "workspace:*",
    "@smarthome/command-flow": "workspace:*",
    "@smarthome/contracts": "workspace:*",
    "@smarthome/db": "workspace:*",
    "@smarthome/mqtt": "workspace:*",
    "@smarthome/realtime": "workspace:*",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/multer": "^1.4.12",
    "@types/ws": "^8.5.13",
    "dotenv-cli": "^8.0.0",
    "rimraf": "^6.0.1"
  }
}
