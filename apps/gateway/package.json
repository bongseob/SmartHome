{
  "name": "@smarthome/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rimraf dist .turbo",
    "start": "dotenv -e ../../.env -- node dist/index.js"
  },
  "dependencies": {
    "@smarthome/command-flow": "workspace:*",
    "@smarthome/contracts": "workspace:*",
    "@smarthome/db": "workspace:*",
    "@smarthome/mqtt": "workspace:*",
    "@smarthome/notify": "workspace:*",
    "@smarthome/realtime": "workspace:*",
    "onvif": "0.8.1"
  },
  "devDependencies": {
    "@smarthome/test-support": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "rimraf": "^6.0.1"
  }
}
