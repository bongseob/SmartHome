{
  "name": "@smarthome/command-flow",
  "version": "0.1.0",
  "private": true,
  "description": "명령 발행 흐름 + Redis 상관 단일 소스 (api·gateway 공용, 드리프트 방지)",
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
